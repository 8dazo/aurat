generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model MasterProfile {
  id        Int      @id @default(autoincrement())
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApplicationHistory {
  id              Int               @id @default(autoincrement())
  jobUrl          String
  atsPlatform     String
  jobTitle        String
  company         String
  matchScore      Float?
  status          String            @default("pending")
  stepsLog        Json              @default("{}")
  customQuestions Json              @default("{}")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  qnaMemories     CustomQnaMemory[]
}

model CustomQnaMemory {
  id                  Int                @id @default(autoincrement())
  questionHash        String             @unique
  questionText        String
  answerText          String
  sourceApplicationId Int
  sourceApplication   ApplicationHistory @relation(fields: [sourceApplicationId], references: [id])
}
